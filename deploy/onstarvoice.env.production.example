# 复制为  server/.env.production  并填好(该文件已被 .gitignore,不会进仓库)
# 部署脚本会把它 scp 成服务器上的 server/.env

PORT=3002
# 与 minilife 同机的本地 PostgreSQL,单独建一个 onstarvoice 库(见 DEPLOY.md 步骤 2)
DATABASE_URL=postgresql://minilife:你的PG密码@127.0.0.1:5432/onstarvoice

# 后台管理员密码(自己设一个强密码)
ADMIN_PASSWORD=换成强密码

# 同源访问其实不需要,但显式放行生产域名更稳妥(插件 chrome-extension:// 已自动放行)
CORS_ORIGINS=https://voice.minilife.online

# ===== LLM(情感/标注/赛道/爆款分析,从你本地 server/.env 抄过来)=====
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_API_ENDPOINT=

# ===== 邮件预警(可选)=====
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ===== 飞书预警(可选)=====
FEISHU_WEBHOOK_URL=
