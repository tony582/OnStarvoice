{
  "manifest_version": 3,
  "name": "OnStarVoice 星语",
  "version": "0.2.0",
  "description": "小红书/抖音/微博AI舆情巡检工具：支持笔记/视频/微博数据采集、评论与客资采集、竞品账号监控、AI选题洞察、Excel/CSV导出与飞书同步。",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "*://www.xiaohongshu.com/*",
    "*://www.douyin.com/*",
    "*://v.douyin.com/*",
    "*://weibo.com/*",
    "*://www.weibo.com/*",
    "*://s.weibo.com/*",
    "*://*.sinaimg.cn/*",
    "*://*.sinaimg.com/*",
    "*://*.weiboimg.cn/*",
    "*://*.weiboimg.com/*",
    "https://api.onstarvoice.local/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3000/*",
    "http://127.0.0.1:3001/*"
  ],
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.douyin.com/*",
        "*://v.douyin.com/*"
      ],
      "js": [
        "utils/capture/douyin-interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://www.xiaohongshu.com/*",
        "*://www.douyin.com/*",
        "*://v.douyin.com/*",
        "*://weibo.com/*",
        "*://www.weibo.com/*",
        "*://s.weibo.com/*"
      ],
      "js": [
        "content-loader.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content-v2.js",
        "utils/*.js",
        "utils/capture/*.js"
      ],
      "matches": [
        "*://www.xiaohongshu.com/*",
        "*://www.douyin.com/*",
        "*://v.douyin.com/*",
        "*://weibo.com/*",
        "*://www.weibo.com/*",
        "*://s.weibo.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  }
}
