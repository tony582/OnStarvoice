# 服务端口
PORT=3000

# ===== LLM 配置 =====
# 支持: gemini / openai / deepseek / qianwen
LLM_PROVIDER=gemini
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-2.0-flash
# 自定义端点（DeepSeek/通义千问等兼容 OpenAI 格式的服务）
# LLM_API_ENDPOINT=https://api.deepseek.com/v1

# ===== 邮件通知 =====
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=OnStarVoice <your-email@qq.com>
EMAIL_TO=admin@example.com

# ===== 预警阈值 =====
ALERT_HIGH_INTERACTION_THRESHOLD=500
ALERT_NEGATIVE_BURST_COUNT=5
ALERT_NEGATIVE_BURST_WINDOW_MINUTES=60

# ===== 管理后台 =====
ADMIN_PASSWORD=admin123

# ===== 飞书 Webhook（可选） =====
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
